package org.main.example;


public class Program {
	public static void showRecord() {
		try {
			for (int count = 1; count <= 10; ++count)
				System.out.println("Count: "+count);
				Thread.sleep(10);
		} catch (InterruptedException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
	}
