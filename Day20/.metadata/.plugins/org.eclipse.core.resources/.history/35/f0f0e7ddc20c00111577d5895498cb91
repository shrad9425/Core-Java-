package org.main.example;


class TickTock{ 
	public void tick() throws InterruptedException {
		synchronized (this) {
			for (int i = 0; i <= 5; i++) {

				System.out.println("Tick " + i++);
				this.wait();
				this.notify();
			}
		}
	}

	public void tock() throws InterruptedException {
		synchronized (this) {
			for (int i = 0; i <= 5; i++) {

				System.out.println("Tock " + i++);
				this.wait();
				this.notify();
			}
		}
	}
}
class Task implements Runnable{
	Thread thread;
	public Task(String name) {
		this.thread = new Thread(this, name);
		this.thread.start();
	}
	private static TickTock tt = new TickTock();
	@Override
	public void run() {
		synchronized (tt) {
			try {
				if (Thread.currentThread().getName().equals("Tickhead")) {
					for (int i = 0; i <= 10; i++) {
						System.out.print("Result	:	");
						tt.tick();
						tt.wait();
						Thread.sleep(250);
					}
					System.out.println();
				} else {
					for (int i = 0; i <= 10; i++) {
						System.out.print("Result	:	");
						tt.tock();
						tt.wait();
						Thread.sleep(250);
					}
				}
			} catch (InterruptedException e) {
				throw new RuntimeException(e);

			}
		}
	}
}
public class Program {
	public static void main(String[] args){
		Task t1 = new Task("Tickhead");
		
		Task t2 = new Task("Tockhead");

	}
}
