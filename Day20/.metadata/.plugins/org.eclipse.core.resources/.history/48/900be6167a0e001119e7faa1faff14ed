package org.main.example;

import java.lang.Thread.State;

public class Program {
	public static void main(String[] args) {
		State state[] = State.values();
		for(State states: state) {
			//System.out.println(states.name()+"	"+states.ordinal());
			System.out.printf("%-10s : %10d\n", states.name(), states.ordinal());
		}
	}
}
