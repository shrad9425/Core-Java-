package org.main.example;


class MovieTicketApp extends Thread{ 
	int total=0;
	@Override
	public void run() {
		for(int i=1; i<=10; i++) {
			total = total+100;
		}
	}
	
}

public class Program {
	public static void main(String[] args){
		MovieTicketApp mt = new MovieTicketApp();
		mt.start();
		System.out.println("Total :" +" Rs");

	}
}
