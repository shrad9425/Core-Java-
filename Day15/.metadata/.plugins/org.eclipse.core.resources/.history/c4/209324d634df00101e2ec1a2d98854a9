package org.example.main;

import java.sql.Date;

class Box<T>{
	T date;
	public Box(T date) {
		this.date = date;
	}
	public T getDate() {
		return date;
	}
}
public class Program {
	public static void main(String[] args) {
		Date dt = new Date(13,12+9,1900+2003);
		Box<Date> b1 = new Box<>(dt);
		Date date = b1.getDate();
		System.out.println(date);
		
	}
}
