package org.main.example;

import java.util.Iterator;
import java.util.Vector;

public class Program {
	public static void main(String[] args) {
		Vector<Integer> v = new Vector<>();
		for(int i=1; i <=10; i++){
			v.add(i);
		}
		Integer in = null;
		Iterator<Integer> itor = v.iterator();
		while(itor.hasNext()) {
			in = itor.next();
			System.out.print(in+" ");
		}
		System.out.println();
		if(in == 3) {
			v.add(22);	
			//v.remove(9);
			System.out.print(itor+" ");
		}
	}
	
	public static void main1(String[] args) {
		Vector<Integer> v = new Vector<>();
		for(int i=1; i <=10; i++){
			v.add(i);
		}
		Integer in = null;
		Iterator<Integer> itor = v.iterator();
		while(itor.hasNext()) {
			in = itor.next();
			System.out.println(in);

			if(in == 10) {
				v.add(12);//java.util.ConcurrentModificationException
			}
		}
	}
}
